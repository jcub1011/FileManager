<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileManager.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="550"
        x:Class="FileManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="900" Height="550"
        Title="FileManager">

    <Design.DataContext>
        <!-- Design-time only; the real DataContext is set in App.axaml.cs. -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Top navigation bar -->
        <Border DockPanel.Dock="Top" Padding="8" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="↑ Up" Command="{Binding GoUpCommand}" />
                <TextBox Text="{Binding CurrentPath}" IsReadOnly="True"
                         VerticalAlignment="Center" MinWidth="500"
                         VerticalContentAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="220,*">
            <!-- Roots / drives sidebar -->
            <ListBox Grid.Column="0" x:Name="RootsList"
                     ItemsSource="{Binding Roots}"
                     DoubleTapped="OnRootDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:FileItemViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Glyph}" />
                            <TextBlock Text="{Binding Name}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Main directory listing -->
            <ListBox Grid.Column="1" x:Name="EntriesList"
                     ItemsSource="{Binding Entries}"
                     DoubleTapped="OnEntryDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:FileItemViewModel">
                        <Grid ColumnDefinitions="Auto,*,120,150" Margin="2">
                            <TextBlock Grid.Column="0" Text="{Binding Glyph}" Margin="0,0,6,0" />
                            <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                       HorizontalAlignment="Right" Foreground="Gray" />
                            <TextBlock Grid.Column="3" Text="{Binding ModifiedDisplay}"
                                       HorizontalAlignment="Right" Foreground="Gray" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>

</Window>
